# Database Configuration
# NOTE: Copy this file to .env and set actual credentials for local development
# DO NOT commit .env file to version control - it's in .gitignore

SOURCE_DB_HOST=source-db
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=source_db
SOURCE_DB_USER=postgres
SOURCE_DB_PASSWORD=CHANGE_ME_locally

TARGET_DB_HOST=target-db
TARGET_DB_PORT=5432
TARGET_DB_NAME=target_db
TARGET_DB_USER=postgres
TARGET_DB_PASSWORD=CHANGE_ME_locally

# Application Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# Environment
ENVIRONMENT=development
